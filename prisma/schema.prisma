generator client {
  provider = "prisma-client-js"
  previewFeatures = ["driverAdapters"]
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model Appointment {
  id        Int      @id @default(autoincrement())
  name      String
  phone     String
  date      String
  time      String
  status    String   @default("pending")
  notes     String?
  createdAt DateTime @default(now())
}

model WeeklySchedule {
  id         Int     @id @default(autoincrement())
  dayOfWeek  Int     @unique
  startTime  String  // legacy — kept para compatibilidad
  endTime    String  // legacy — kept para compatibilidad
  isActive   Boolean @default(false)
  timeRanges String? // JSON: [{"start":"09:00","end":"13:00"},{"start":"16:00","end":"20:00"}]
}

model BlockedDate {
  id   Int    @id @default(autoincrement())
  date String @unique
  note String?
}
